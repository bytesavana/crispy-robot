# Base URL of the didactic-invention AG-UI agent server.
# Simulator/emulator default works as-is. On a physical device, "localhost" resolves
# to the phone itself, not your dev machine — use your machine's LAN IP instead, e.g.:
#   EXPO_PUBLIC_AGENT_API_URL=http://192.168.1.23:8000
# Find it on macOS with: ipconfig getifaddr en0
EXPO_PUBLIC_AGENT_API_URL=http://localhost:8000
